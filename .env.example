# OSS Navigator — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ─── Application ─────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-long-random-string
LOG_LEVEL=INFO

# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://opensync:opensync@localhost:5432/opensync
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Qdrant ──────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_REPOS=repositories

# ─── GitHub API ──────────────────────────────────────────
# Create at: https://github.com/settings/tokens
# Required scopes: read:user, read:org, public_repo
GITHUB_TOKEN=ghp_your_token_here
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── ML / Embeddings ─────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=32

# ─── LLM (Phase 4) ───────────────────────────────────────
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=1000

# ─── Frontend ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000